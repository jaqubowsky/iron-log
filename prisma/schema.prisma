// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  password         String
  tokens           RefreshToken[]
  workoutTemplates WorkoutTemplate[]
  workoutLogs      WorkoutLog[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model RefreshToken {
  id         String   @id @default(uuid())
  valid      Boolean  @default(true)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  expiration DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum ExerciseCategory {
  NECK
  SHOULDERS
  ARMS
  BACK
  CHEST
  CORE
  LEGS
}

model Exercise {
  id                  String                       @id @default(uuid())
  name                String
  description         String?
  category            ExerciseCategory
  workoutTemplates    ExercisesOnWorkoutTemplate[]
  workoutLogExercises WorkoutLogExercise[]
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
}

model ExercisesOnWorkoutTemplate {
  workoutTemplate   WorkoutTemplate @relation(fields: [workoutTemplateId], references: [id], onDelete: Cascade)
  workoutTemplateId String
  exercise          Exercise        @relation(fields: [exerciseId], references: [id])
  exerciseId        String
  order             Int

  @@id([workoutTemplateId, exerciseId])
}

model WorkoutTemplate {
  id          String                       @id @default(uuid())
  name        String
  description String?
  exercises   ExercisesOnWorkoutTemplate[]
  user        User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  workoutLogs WorkoutLog[]
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt
}

model WorkoutLogExercise {
  id                 String                  @id @default(uuid())
  name               String
  description        String?
  category           ExerciseCategory
  order              Int
  sets               WorkoutLogExerciseSet[]
  originalExercise   Exercise?               @relation(fields: [originalExerciseId], references: [id], onDelete: SetNull)
  originalExerciseId String?
  workoutLog         WorkoutLog              @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)
  workoutLogId       String
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
}

model WorkoutLogExerciseSet {
  id                   String             @id @default(uuid())
  weight               Float
  reps                 Int
  rpe                  Int
  order                Int
  notes                String?
  workoutLogExercise   WorkoutLogExercise @relation(fields: [workoutLogExerciseId], references: [id], onDelete: Cascade)
  workoutLogExerciseId String
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model WorkoutLog {
  id                  String               @id @default(uuid())
  name                String
  description         String?
  workoutLogExercises WorkoutLogExercise[]
  workoutTemplate     WorkoutTemplate?     @relation(fields: [workoutTemplateId], references: [id], onDelete: SetNull)
  workoutTemplateId   String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId              String
}
