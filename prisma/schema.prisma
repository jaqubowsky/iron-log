// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum ExerciseCategory {
  NECK
  SHOULDERS
  ARMS
  BACK
  CHEST
  CORE
  LEGS
}

model Exercise {
  id          String                       @id @default(uuid())
  name        String
  description String?
  category    ExerciseCategory
  workoutLogs ExercisesOnWorkoutTemplate[]
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt
}

model ExercisesOnWorkoutTemplate {
  workoutTemplate   WorkoutTemplate @relation(fields: [workoutTemplateId], references: [id], onDelete: Cascade)
  workoutTemplateId String
  exercise          Exercise        @relation(fields: [exerciseId], references: [id])
  exerciseId        String
  order             Int

  @@id([workoutTemplateId, exerciseId])
}

model WorkoutTemplate {
  id          String                       @id @default(uuid())
  name        String
  description String?
  exercises   ExercisesOnWorkoutTemplate[]
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt
}
